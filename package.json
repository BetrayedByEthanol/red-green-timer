{
  "name": "red-green-timer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "format:check": "cargo fmt --all --check",
    "lint:frontend": "svelte-check --tsconfig ./tsconfig.json",
