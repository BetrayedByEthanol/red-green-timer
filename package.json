    "lint": "npm run lint:frontend && npm run lint:rust"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tauri-apps/cli": "2.11.4",
    "@tsconfig/svelte": "5.0.6",
    "esbuild": "0.28.1",
    "svelte": "5.56.5",
    "svelte-check": "4.7.3",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  }
}
